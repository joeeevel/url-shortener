{
  "name": "url-shortener",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "docker-up": "docker-compose up -d",
    "docker-down": "docker compose down",
    "docker-log": "docker-compose logs -f",
    "migrate": "docker-compose exec app npx prisma migrate dev",
    "studio": "docker-compose exec app npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "express": "^4.18.2",
    "ioredis": "^5.11.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "URL shortener with Docker, PostgreSQL, and Redis"
}
